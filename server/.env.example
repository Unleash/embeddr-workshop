# Client API URL for your Unleash instance, ending in /api (no trailing slash beyond that)
UNLEASH_API_URL=https://your-instance.getunleash.io/api
# Backend token for the development environment
UNLEASH_CLIENT_TOKEN=your-backend-token
# Frontend origin allowed by CORS
ALLOWED_ORIGIN=http://localhost:5173
# Port the backend listens on
PORT=3001
# Metrics reporting interval in milliseconds, lower it for the live demo
METRICS_INTERVAL=60000