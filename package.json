{
  "name": "embeddr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "npm run start --prefix server",
    "postinstall": "npm --prefix server install",
    "dev": "concurrently -n web,api -c auto \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm run dev --prefix server",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
